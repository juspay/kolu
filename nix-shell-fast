#!/usr/bin/env bash
#
# nix-shell-fast — cached `nix-shell ... --run` replacement (~0.015s vs ~2.5s)
#
# Runs a command inside the shell.nix environment, caching the full set of
# exported env vars (PATH, PLAYWRIGHT_BROWSERS_PATH, etc.) on first use.
# Subsequent calls eval the cache and exec directly, skipping nix entirely.
#
# Cache invalidation:
#   The cache key is a content hash of the nix files listed below. Any byte
#   change to a listed file produces a new key → cache miss → full re-eval.
#
#   IMPORTANT: if you add a new .nix file that shell.nix or default.nix
#   imports, add it to the CACHE_KEY cat list below. Otherwise changes to
#   that file won't invalidate the cache.
#
# Known limitations:
#   - shellHook side-effects (pre-commit install, font symlinks) only run
#     on cache miss. The cache stores the *result* (env vars), not the
#     commands. Run `rm -rf ~/.cache/kolu-shell` to force a full re-eval.
#   - Only one store path is checked for GC validity. A partial GC could
#     leave a stale cache. Same fix: rm the cache dir.
#
# Usage:
#   ./nix-shell-fast pnpm install        # like: nix-shell shell.nix --run 'pnpm install'
#   ./nix-shell-fast just dev             # any command works
#
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/kolu-shell"

# Cache key: content hash of all nix input files.
# Add new .nix files here when they affect the shell environment.
CACHE_KEY=$(cat "$DIR/shell.nix" "$DIR/default.nix" "$DIR/nix/nixpkgs.nix" \
    "$DIR"/nix/fonts/default.nix "$DIR"/nix/ghostty-themes/default.nix \
    "$DIR"/nix/ghostty-themes/parse-themes.py 2>/dev/null | sha256sum | cut -d' ' -f1)
ENV_FILE="$CACHE_DIR/$CACHE_KEY.env"

# Validate cache: file exists and first nix store path in PATH is still valid
cache_valid() {
  [[ -f "$ENV_FILE" ]] || return 1
  local store_path
  store_path=$(grep '^declare -x PATH=' "$ENV_FILE" | grep -o '/nix/store/[^/:]*' | head -1)
  [[ -n "$store_path" ]] && [[ -e "$store_path" ]]
}

if ! cache_valid; then
  mkdir -p "$CACHE_DIR"
  find "$CACHE_DIR" -maxdepth 1 -type f -not -name "$CACHE_KEY.*" -delete 2>/dev/null || true
  nix-shell "$DIR/shell.nix" --run 'export -p' 2>/dev/null | grep '^declare -x ' > "$ENV_FILE.tmp"
  mv "$ENV_FILE.tmp" "$ENV_FILE"
fi

eval "$(cat "$ENV_FILE")"
exec "$@"
