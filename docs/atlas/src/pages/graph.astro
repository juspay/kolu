---
import { getCollection } from "astro:content";
import ForceGraph from "../components/ForceGraph.astro";
import MocHubs from "../components/MocHubs.astro";
import AtlasLayout from "../layouts/AtlasLayout.astro";
import { buildAtlasGraph } from "../lib/atlasGraph";
import { buildGraphLayout } from "../lib/graphView";

// The Atlas as a graph + its Maps of Content. Same production note set as the
// index/[...slug] (drafts hidden from the build, reachable in `astro dev`), so
// the graph, the dead-link gate, and the backlinks all see one note set. The
// force layout is computed here at build time (lib/graphView → d3-force) and
// baked into a static, self-contained inline SVG — no runtime layout, no bundle.
const notes = (await getCollection("atlas")).filter(
  (n) => import.meta.env.DEV || !n.data.draft,
);
const graph = buildAtlasGraph(notes);
const layout = buildGraphLayout(notes, graph);

const kinds = [
  { key: "reference", label: "reference" },
  { key: "feature", label: "feature" },
  { key: "analysis", label: "analysis" },
  { key: "bug", label: "bug" },
];
---

<AtlasLayout
  title="Graph"
  description="The kolu Atlas as a force-directed graph, with its Maps of Content — the hub notes everything else hangs off."
>
  <div class="wrap wrap-graph">
    <a class="backlink" href="./index.html">← the Atlas</a>
    <p class="eyebrow">graph &amp; maps of content</p>
    <h1 class="atlas-title">The <span class="accent">graph</span>.</h1>
    <p class="lede">
      Every note, wired by the links it already has — <code>parents</code> edges and
      same-directory references. Bigger circles are the <strong>hubs</strong>: the
      notes most of the Atlas points at. Hover to trace a note's neighborhood; click
      to open it. The <strong>{layout.nodes.length}</strong> notes,
      <strong>{layout.edges.length}</strong> links.
    </p>

    <div class="graph-legend">
      <div class="legend-group">
        <span class="legend-cap">kind</span>
        {
          kinds.map((k) => (
            <span class="legend-item">
              <span class={`legend-swatch k-${k.key}`} />
              {k.label}
            </span>
          ))
        }
      </div>
      <div class="legend-group">
        <span class="legend-cap">maturity</span>
        <span class="legend-item"><span class="legend-ring m-seedling" />seedling</span>
        <span class="legend-item"><span class="legend-ring m-budding" />budding</span>
        <span class="legend-item"><span class="legend-ring m-evergreen" />evergreen</span>
      </div>
      <div class="legend-group">
        <span class="legend-cap">edge</span>
        <span class="legend-item"><span class="legend-line solid" />parent</span>
        <span class="legend-item"><span class="legend-line dashed" />reference</span>
      </div>
    </div>

    <ForceGraph viewBox={layout.viewBox} nodes={layout.nodes} edges={layout.edges} />

    <div class="moc-head">
      <h2 class="moc-h">Maps of Content</h2>
      <p class="moc-sub">
        The hubs, ranked by how many notes point at them. Each lists its cluster —
        the notes that reference it. No hand-curated index: these fall straight out
        of the links the Atlas already has.
      </p>
    </div>
    <MocHubs hubs={layout.hubs} />

    <footer class="note-foot">
      <a class="backlink" href="./index.html">← the Atlas</a>
      <a class="backlink" href="https://github.com/juspay/kolu" rel="noopener">github ↗</a>
    </footer>
  </div>
</AtlasLayout>

<style>
  .wrap-graph {
    max-width: 60rem;
  }
  .wrap-graph .atlas-title {
    margin-top: 0.4rem;
  }
  .wrap-graph .lede {
    margin-bottom: 1.6rem;
  }

  .graph-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.6rem;
    margin: 0 0 1rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--rule);
    border-radius: 10px;
    background: var(--surface);
  }
  .legend-group {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.9rem;
  }
  .legend-cap {
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--mono);
    font-size: 0.66rem;
    color: var(--ink-muted);
  }
  .legend-swatch {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }
  .legend-swatch.k-bug {
    background: var(--alert);
  }
  .legend-swatch.k-feature {
    background: var(--teal);
  }
  .legend-swatch.k-analysis {
    background: var(--gold);
  }
  .legend-swatch.k-reference {
    background: var(--ink-muted);
  }
  .legend-ring {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--surface);
    border: 1.5px solid var(--ink-faint);
  }
  .legend-ring.m-seedling {
    border-color: var(--gold);
  }
  .legend-ring.m-budding {
    border-color: var(--teal);
  }
  .legend-ring.m-evergreen {
    border-color: var(--green);
  }
  .legend-line {
    width: 16px;
    height: 0;
    border-top: 1.5px solid var(--ink-faint);
  }
  .legend-line.dashed {
    border-top-style: dashed;
  }

  .moc-head {
    margin: 3rem 0 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .moc-h {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0;
  }
  .moc-sub {
    margin: 0.5rem 0 0;
    max-width: 42rem;
    font-size: 0.9rem;
    color: var(--ink-muted);
  }
</style>
