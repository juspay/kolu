---
import { getCollection, render } from "astro:content";
import AtlasLayout from "../layouts/AtlasLayout.astro";
import Toc from "../components/Toc.astro";
import Backlinks from "../components/Backlinks.astro";
import { buildAtlasGraph } from "../lib/atlasGraph";

export async function getStaticPaths() {
  // Match index.astro's working set: drafts are hidden from the build (but
  // reachable in `astro dev`), so backlink sources/targets and the dead-link
  // gate all see the same production note set the index does.
  const notes = (await getCollection("atlas")).filter(
    (n) => import.meta.env.DEV || !n.data.draft,
  );
  // Build the inbound link graph once for the whole collection (and fail the
  // build on any dead internal link), then hand each page its own backlinks.
  const { backlinks } = buildAtlasGraph(notes);
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note, backlinks: backlinks.get(note.id) ?? [] },
  }));
}

const { note, backlinks } = Astro.props;
const { Content, headings } = await render(note);
const d = note.data;

// Date-only frontmatter (`2026-06-02`) parses to UTC midnight; format in UTC so a
// build machine in a negative-offset timezone doesn't render the label a day early.
const fmtDate = (date: Date) =>
  date
    .toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "2-digit",
      timeZone: "UTC",
    })
    .toUpperCase();
---

<AtlasLayout title={d.title} description={d.description}>
  <article class="wrap">
    <header>
      <a class="backlink" href="./index.html">← the Atlas</a>

      <h1 class="note-h1">{d.title}</h1>

      <div class="meta-row">
        <span>{d.kind}</span>
        <span class="meta-sep">·</span>
        <span>{d.maturity}</span>
        {d.status && (<><span class="meta-sep">·</span><span>{d.status}</span></>)}
        {d.draft && (<><span class="meta-sep">·</span><span class="badge-draft">draft</span></>)}
        {d.updated && (<><span class="meta-sep">·</span><time datetime={d.updated.toISOString()}>{fmtDate(d.updated)}</time></>)}
      </div>

      <p class="note-sub">{d.description}</p>

      <Toc headings={headings} />
    </header>

    <div class="prose">
      <Content />
    </div>

    <Backlinks notes={backlinks} />

    <footer class="note-foot">
      <a class="backlink" href="./index.html">← the Atlas</a>
      <a class="backlink" href="https://github.com/juspay/kolu" rel="noopener">github ↗</a>
    </footer>
  </article>
</AtlasLayout>
