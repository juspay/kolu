---
// Compact, recursive tree for one category section. One row per note (maturity
// dot · title · truncated description · flags); same-category children nest under
// their parent via Astro.self with an indent guide — the within-section
// hierarchy. A cross-category parent is shown as a `related` link under the row,
// not as a tree edge. Scales to ~100 links. Links stay relative (`./slug.html`)
// so they resolve in kolu's Code tab AND on the web at kolu.dev/atlas/.
import type { CatTreeNode } from "../lib/indexTree";

interface Props {
  nodes: CatTreeNode[];
  ancestors?: string[];
  sub?: boolean;
}
const { nodes, ancestors = [], sub = false } = Astro.props as Props;
---
<ul class={sub ? "moc-sub" : "moc"}>
  {
    nodes.map((node) => {
      const path = [...ancestors, node.note.id];
      const children = node.children.filter((c) => !path.includes(c.note.id));
      const d = node.note.data;
      return (
        <li>
          <a class="row" href={`./${node.note.id}.html`} title={d.description}>
            <span class={`row-dot m-${d.maturity}`} />
            <span class="row-t">{d.title}</span>
            <span class="row-d">{d.description}</span>
            {d.status && <span class="row-flag is-status">{d.status}</span>}
            {d.draft && <span class="row-flag is-draft">draft</span>}
          </a>
          {node.related.length > 0 && (
            <div class="row-rel">
              <span class="row-rel-lead">related</span>
              {node.related.map((r, i) => (
                <>
                  {i > 0 && <span class="row-rel-sep">·</span>}
                  <a href={`./${r.id}.html`}>{r.title}</a>
                </>
              ))}
            </div>
          )}
          {children.length > 0 && <Astro.self nodes={children} ancestors={path} sub={true} />}
        </li>
      );
    })
  }
</ul>
