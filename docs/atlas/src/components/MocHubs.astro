---
// "Maps of Content" — the single entry index. Every hub is a card:
//   - the four KIND hubs (Bugs/Features/Analysis/Reference), each listing ALL its
//     notes — so the four cards together name every note, and the page is fully
//     navigable with no JS;
//   - TOPICAL hubs (electricity, solid-fileview, …), each listing its cluster —
//     the cross-cutting entry points the link graph surfaces on its own.
// Kind cards carry the `#moc-<kind>` anchor a kind chip in the graph links to, and
// every card's `data-hub` lights up its node + neighborhood in the graph on hover.
import type { HubCard } from "../lib/graphView";

interface Props {
  hubs: HubCard[];
}
const { hubs } = Astro.props as Props;
---

<section class="moc-hubs" aria-label="Maps of Content">
  <div class="moc-grid">
    {
      hubs.map((h) => (
        <article
          class={`hub-card kind-${h.kind}${h.isKind ? " is-kind" : ""}`}
          id={h.anchorId}
          data-hub={h.id}
        >
          <header class="hub-head">
            <span class="hub-bar" />
            {h.href ? (
              <a class="hub-title" href={h.href}>
                {h.label}
              </a>
            ) : (
              <span class="hub-title">{h.label}</span>
            )}
            <span class="hub-count">
              {h.count} {h.countLabel}
            </span>
          </header>
          <p class="hub-desc">{h.description}</p>
          <ul class="cluster">
            {h.cluster.map((c) => (
              <li>
                <a class="cluster-row" href={`./${c.id}.html`}>
                  <span class={`cluster-dot m-${c.maturity}`} />
                  <span class="cluster-t">{c.title}</span>
                  {h.isKind ? (
                    <span class="cluster-d">{c.description}</span>
                  ) : (
                    <span class={`cluster-kind k-${c.kind}`}>{c.kind}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>

<style>
  .moc-hubs {
    margin: 2rem 0 0;
  }
  .moc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    align-items: start;
    gap: 1rem;
  }
  .hub-card {
    background: var(--surface);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--cat-color, var(--ink-muted));
    border-radius: 12px;
    padding: 1rem 1.1rem 1.1rem;
    scroll-margin-top: 1.5rem;
    transition: box-shadow 0.15s ease;
  }
  .hub-card:hover {
    box-shadow:
      0 1px 0 var(--rule),
      0 6px 20px -14px rgba(26, 28, 32, 0.4);
  }
  /* kind cards are the index — let them span two columns on wide grids so the
     complete listings breathe and don't tower in a single narrow column */
  .hub-card.is-kind {
    grid-column: span 2;
  }
  @media (max-width: 660px) {
    .hub-card.is-kind {
      grid-column: span 1;
    }
  }
  .hub-card.kind-bug {
    --cat-color: var(--alert);
  }
  .hub-card.kind-feature {
    --cat-color: var(--teal);
  }
  .hub-card.kind-analysis {
    --cat-color: var(--gold);
  }
  .hub-card.kind-reference {
    --cat-color: var(--ink-muted);
  }

  .hub-head {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .hub-bar {
    align-self: center;
    flex: none;
    width: 8px;
    height: 8px;
    border-radius: 3px;
    background: var(--cat-color);
  }
  .hub-title {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
  }
  a.hub-title:hover {
    color: var(--amber);
  }
  .hub-count {
    margin-left: auto;
    flex: none;
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .hub-desc {
    margin: 0.5rem 0 0.7rem;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--ink-muted);
  }

  .cluster {
    list-style: none;
    margin: 0;
    padding: 0.7rem 0 0;
    border-top: 1px solid var(--rule-soft);
    display: grid;
    gap: 0.05rem;
  }
  /* kind cards (the full index) flow their long listings into columns */
  .is-kind .cluster {
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.05rem 1.4rem;
  }
  .cluster-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.2rem 0.3rem;
    border-radius: 6px;
    text-decoration: none;
    min-width: 0;
  }
  .cluster-row:hover {
    background: var(--paper);
  }
  .cluster-row:hover .cluster-t {
    color: var(--amber);
  }
  .cluster-dot {
    flex: none;
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .cluster-dot.m-seedling {
    background: var(--gold);
  }
  .cluster-dot.m-budding {
    background: var(--teal);
  }
  .cluster-dot.m-evergreen {
    background: var(--green);
  }
  .cluster-t {
    flex: none;
    max-width: 100%;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--ink-dim);
  }
  .cluster-d {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-size: 0.78rem;
    color: var(--ink-faint);
  }
  .cluster-kind {
    margin-left: auto;
    flex: none;
    font-family: var(--mono);
    font-size: 0.56rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .cluster-kind.k-bug {
    color: var(--alert);
  }
  .cluster-kind.k-feature {
    color: var(--teal);
  }
  .cluster-kind.k-analysis {
    color: var(--gold);
  }
  .cluster-kind.k-reference {
    color: var(--ink-faint);
  }
</style>
