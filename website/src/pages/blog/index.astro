---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (p: string) => `${base}${p}` || '/';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog" description="Notes from building Kolu.">
  <section class="mx-auto max-w-3xl px-6 pt-20 md:pt-28 pb-10">
    <p class="eyebrow mb-4">the blog</p>
    <h1 class="display text-[3.2rem] md:text-[4.2rem] text-ink">
      Notes <span class="text-amber">from</span><br />building kolu.
    </h1>
    <p class="mt-6 text-ink-dim max-w-xl leading-relaxed">
      Investigations, post-mortems, design threads. Mostly written after
      something broke.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 pb-20">
    <ul class="border-t border-rule">
      {
        posts.map((post) => (
          <li class="border-b border-rule">
            <a
              href={href(`/blog/${post.id}`)}
              class="group block py-8 -mx-6 px-6 hover:bg-void-raised/60 transition-colors relative"
            >
              <span
                aria-hidden="true"
                class="absolute left-0 top-0 bottom-0 w-px bg-amber scale-y-0 group-hover:scale-y-100 origin-center transition-transform"
              />
              <div class="grid md:grid-cols-[8rem_1fr] gap-1 md:gap-6 md:items-baseline">
                <time
                  class="mono text-[0.72rem] text-ink-muted tracking-widest"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {post.data.pubDate
                    .toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: '2-digit',
                    })
                    .toUpperCase()}
                </time>
                <div>
                  <h2 class="display-sm text-[1.7rem] md:text-[1.95rem] text-ink group-hover:text-amber transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="mt-3 text-ink-dim leading-relaxed">
                    {post.data.description}
                  </p>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    {
      posts.length === 0 && (
        <p class="mono text-ink-muted text-sm py-12 text-center">
          // no posts yet
        </p>
      )
    }
  </section>
</BaseLayout>
