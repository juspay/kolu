---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TOC from '../../components/TOC.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (p: string) => `${base}${p}` || '/';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);

const minutesRead = remarkPluginFrontmatter?.minutesRead;

// Show a table of contents only when the post is long enough to need one.
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const showToc = tocHeadings.length >= 4;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImageRoute={`blog/${post.id}`}
  ogType="article"
  pubDate={post.data.pubDate}
  author={post.data.author}
>
  <article class="mx-auto max-w-[44rem] px-6 pt-20 pb-24">
    <header class="mb-14">
      <a
        href={href('/blog')}
        class="mono text-[0.72rem] text-ink-muted hover:text-amber transition-colors tracking-widest"
      >
        ← all posts
      </a>

      <h1 class="display mt-8 text-[2.8rem] md:text-[3.6rem] text-ink">
        {post.data.title}
      </h1>

      <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 mono text-[0.72rem] text-ink-muted tracking-widest">
        <time datetime={post.data.pubDate.toISOString()}>
          {
            post.data.pubDate
              .toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: '2-digit',
              })
              .toUpperCase()
          }
        </time>
        <span class="text-ink-faint">·</span>
        <a
          href={post.data.authorUrl}
          rel="author noopener"
          class="hover:text-amber transition-colors"
        >
          {post.data.author}
        </a>
        {
          minutesRead && (
            <>
              <span class="text-ink-faint">·</span>
              <span>{minutesRead}</span>
            </>
          )
        }
      </div>
    </header>

    {showToc && <TOC headings={headings} />}

    <div class="prose prose-editorial max-w-none">
      <Content />
    </div>

    <footer class="mt-20 pt-8 border-t border-rule flex items-center justify-between">
      <a
        href={href('/blog')}
        class="mono text-[0.72rem] text-ink-dim hover:text-amber transition-colors tracking-widest"
      >
        ← all posts
      </a>
      <a
        href="https://github.com/juspay/kolu"
        rel="noopener"
        class="mono text-[0.72rem] text-ink-dim hover:text-amber transition-colors tracking-widest"
      >
        github ↗
      </a>
    </footer>
  </article>
</BaseLayout>
