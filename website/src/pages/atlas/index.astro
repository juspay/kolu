---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (p: string) => `${base}${p}` || "/";

// Generated index: derived from the collection's frontmatter. Drafts are
// hidden from the public build but stay reachable in `astro dev`. A note can
// never be "unfiled" — so this replaces the hand-curated MOC and the CI gate.
const notes = (await getCollection("atlas"))
  .filter((n) => import.meta.env.DEV || !n.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const KINDS = ["plan", "design", "review", "retro", "research", "decision"] as const;
const byKind = (k: string) => notes.filter((n) => n.data.kind === k);
const maturityColor: Record<string, string> = {
  seedling: "text-live-lime",
  budding: "text-live-teal",
  evergreen: "text-amber",
};
---

<BaseLayout
  title="Atlas"
  description="kolu's in-repo Atlas — plans, designs, reviews, and learnings, authored in markdown."
  defaultTheme="light"
>
  <section class="mx-auto max-w-3xl px-6 pt-20 md:pt-28 pb-8">
    <p class="eyebrow mb-4">the atlas</p>
    <h1 class="display text-[3.2rem] md:text-[4.2rem] text-ink">
      The <span class="text-amber">Atlas</span>.
    </h1>
    <p class="mt-6 text-ink-dim max-w-xl leading-relaxed">
      kolu's in-repo knowledge base — authored in markdown, rendered here. This
      index is generated from each note's frontmatter, so there is no
      hand-curated map to drift and nothing can fall through unfiled.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 pb-24">
    {
      KINDS.map((k) =>
        byKind(k).length > 0 ? (
          <div class="mb-10">
            <h2 class="mono text-[0.72rem] text-ink-muted tracking-widest uppercase border-b border-rule pb-2 mb-1">
              {k}
            </h2>
            <ul>
              {byKind(k).map((n) => (
                <li class="border-b border-rule">
                  <a
                    href={href(`/atlas/${n.id}`)}
                    class="group block py-6 -mx-6 px-6 hover:bg-void-raised/60 transition-colors"
                  >
                    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                      <h3 class="display-sm text-[1.5rem] text-ink group-hover:text-amber transition-colors">
                        {n.data.title}
                      </h3>
                      <span
                        class={`mono text-[0.62rem] tracking-widest uppercase ${maturityColor[n.data.maturity]}`}
                      >
                        {n.data.maturity}
                      </span>
                      {n.data.status && (
                        <span class="mono text-[0.62rem] tracking-widest uppercase text-ink-muted">
                          {n.data.status}
                        </span>
                      )}
                      {n.data.draft && (
                        <span class="mono text-[0.62rem] tracking-widest uppercase text-live-alert">
                          draft
                        </span>
                      )}
                    </div>
                    <p class="mt-2 text-ink-dim leading-relaxed">{n.data.description}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ) : null,
      )
    }
    {
      notes.length === 0 && (
        <p class="mono text-ink-muted text-sm py-12 text-center">// the Atlas is empty</p>
      )
    }
  </section>
</BaseLayout>
