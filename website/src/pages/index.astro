  }
  .c-ok {
    color: var(--color-live-lime);
  }

  /* ── Callouts ───────────────────────────────────────────────────────── */
  .callout {
    border: 1px solid var(--color-rule);
    border-left-width: 3px;
    border-radius: 0.5rem;
    padding: 0.95rem 1.15rem;
    margin-block: 1.6rem;
