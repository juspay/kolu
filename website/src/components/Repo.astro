---
/**
 * Inline reference to a GitHub repository, rendered as a small GitHub-style
 * token: the GitHub mark followed by the monospace `owner/repo`. Themed via the
 * global CSS custom properties, so it tracks light/dark automatically. Pairs
 * with <PR /> (which references a single PR/issue); this one points at a repo.
 *
 *   <Repo slug="juspay/odu" />                 → ⎇ juspay/odu
 *   <Repo slug="juspay/odu" label="odu" />     → ⎇ odu   (custom display text)
 *   <Repo slug="juspay/odu" prominent />       → a larger pill, for a header/top-of-post link
 *
 * Props: slug (required, "owner/repo"); label (optional display text, defaults
 * to the slug); prominent (optional, renders the larger header variant).
 */
interface Props {
  slug: string;
  label?: string;
  prominent?: boolean;
}

const { slug, label, prominent = false } = Astro.props;
const href = `https://github.com/${slug}`;
const text = label ?? slug;

// Octicons mark-github, 16px.
const MARK_GITHUB =
  "M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z";
---

<a
  class:list={["repo-ref", { prominent }]}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  <svg
    class="repo-ref-icon"
    viewBox="0 0 16 16"
    width="1em"
    height="1em"
    aria-hidden="true"
    fill="currentColor"
  >
    <path d={MARK_GITHUB}></path>
  </svg><span class="repo-ref-text">{text}</span>
</a>

<style>
  .repo-ref {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: 0.82em;
    font-weight: 500;
    line-height: 1;
    padding: 0.16em 0.6em 0.16em 0.5em;
    border-radius: 2em;
    text-decoration: none;
    white-space: nowrap;
    vertical-align: baseline;
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-ink) 7%, transparent);
    border: 1px solid var(--color-rule-strong);
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .repo-ref:hover {
    background: color-mix(in srgb, var(--color-ink) 12%, transparent);
    border-color: var(--color-ink-muted);
  }
  /* Larger header variant — a top-of-post "view the repo" link. */
  .repo-ref.prominent {
    font-size: 0.95em;
    padding: 0.42em 0.85em 0.42em 0.72em;
    gap: 0.5em;
  }
  .repo-ref-icon {
    flex: none;
  }
</style>
