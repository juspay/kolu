---
const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (p: string) => `${base}${p}` || '/';

// Astro's pathname always starts with the configured `base`; strip it before
// comparing so "/kolu/blog" still matches as "/blog".
const normalized = pathname.replace(new RegExp(`^${base}`), '') || '/';
const isActive = (p: string) =>
  p === '/' ? normalized === '/' : normalized.startsWith(p);

const nav = [
  { label: 'Blog', href: href('/blog'), path: '/blog' },
  { label: 'GitHub', href: 'https://github.com/juspay/kolu', external: true },
];
---

<header class="sticky top-0 z-10 border-b border-rule backdrop-blur-xs bg-void/80">
  <div class="mx-auto max-w-[68rem] px-6 h-14 flex items-center justify-between">
    <a
      href={href('/')}
      class="flex items-center gap-2.5 group"
      aria-label="kolu home"
    >
      <img
        src={href('/favicon.svg')}
        alt=""
        class="size-5 transition-transform group-hover:-translate-y-px"
      />
      <span class="font-serif text-[1.05rem] leading-none" style="font-variation-settings: 'opsz' 72, 'SOFT' 20, 'WONK' 1;">
        kolu
      </span>
    </a>

    <nav class="flex items-center gap-5 sm:gap-7 mono text-[0.78rem]">
      {
        nav.map((item) =>
          'external' in item ? (
            <a
              href={item.href}
              rel="noopener"
              class="text-ink-dim hover:text-amber transition-colors flex items-center gap-1.5"
            >
              <span>{item.label}</span>
              <span class="text-ink-faint" aria-hidden="true">↗</span>
            </a>
          ) : (
            <a
              href={item.href}
              class:list={[
                'transition-colors',
                isActive(item.path) ? 'text-amber' : 'text-ink-dim hover:text-ink',
              ]}
            >
              {item.label}
            </a>
          ),
        )
      }

      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle light/dark theme"
        class="relative size-7 rounded-sm border border-transparent hover:border-rule text-ink-dim hover:text-amber transition-colors flex items-center justify-center"
      >
        {/* Sun — shown in dark mode (click to go light) */}
        <svg
          class="theme-icon-sun absolute size-4 transition-all"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="8" cy="8" r="3" />
          <path d="M8 1v2M8 13v2M15 8h-2M3 8H1M13 3l-1.4 1.4M4.4 11.6L3 13M13 13l-1.4-1.4M4.4 4.4L3 3" />
        </svg>
        {/* Moon — shown in light mode (click to go dark) */}
        <svg
          class="theme-icon-moon absolute size-4 transition-all"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M13.8 9.4a5.5 5.5 0 0 1-7.2-7.2.6.6 0 0 0-.8-.8 7 7 0 1 0 8.8 8.8.6.6 0 0 0-.8-.8Z" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("theme-toggle");
  btn?.addEventListener("click", () => {
    const html = document.documentElement;
    const next = html.dataset.theme === "dark" ? "light" : "dark";
    html.dataset.theme = next;
    localStorage.setItem("theme", next);
  });
</script>
