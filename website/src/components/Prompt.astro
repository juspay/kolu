---
/**
 * A line the author typed into Claude Code's CLI prompt box during the build —
 * rendered to *look* like that input field (rounded coral-bordered box, a `>`
 * mark, a blinking block cursor, and Claude Code's `⏵⏵ accept edits on` hint
 * row), so a quoted instruction reads as "a human typed this into the agent,"
 * not as a generic blockquote or a shell command. Pairs with the blog's
 * narrative voice where the real verbatim prompts are the turning points.
 *
 *   <Prompt>so the user can actually see</Prompt>
 *
 * The slot is the typed text. Coral (#d97757) is Claude's own accent — not the
 * site's amber — so the box reads as Claude Code on sight. Cursor blink stops
 * under prefers-reduced-motion.
 */
---

<div class="cc-prompt">
  <div class="cc-prompt-box">
    <span class="cc-prompt-mark" aria-hidden="true">&gt;</span>
    <span class="cc-prompt-text"
      ><slot /><span class="cc-prompt-cursor" aria-hidden="true"></span></span
    >
  </div>
  <div class="cc-prompt-hint" aria-hidden="true">
    <span class="cc-prompt-chevrons">⏵⏵</span>
    accept edits on <span class="cc-prompt-dim">(shift+tab to cycle)</span>
  </div>
</div>

<style>
  .cc-prompt {
    margin: 1.6rem 0;
    font-family: var(--font-mono);
    font-size: 0.86em;
    line-height: 1.5;
  }
  /* The rounded, coral-edged input box — Claude Code's prompt field. */
  .cc-prompt-box {
    display: flex;
    align-items: flex-start;
    gap: 0.55em;
    color: var(--color-ink);
    background: var(--color-void-sunk);
    border: 1px solid color-mix(in srgb, #d97757 50%, var(--color-rule-strong));
    border-radius: 0.6rem;
    padding: 0.62rem 0.8rem;
  }
  .cc-prompt-mark {
    flex: none;
    color: #d97757;
    user-select: none;
  }
  .cc-prompt-text {
    flex: 1;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .cc-prompt-cursor {
    display: inline-block;
    width: 0.5em;
    height: 1.05em;
    margin-left: 0.1em;
    vertical-align: text-bottom;
    background: #d97757;
    animation: cc-prompt-blink 1.1s steps(1, end) infinite;
  }
  /* Claude Code's hint row beneath the box. */
  .cc-prompt-hint {
    margin: 0.42rem 0 0 0.3rem;
    font-size: 0.92em;
    color: color-mix(in srgb, #d97757 65%, var(--color-ink-muted));
    user-select: none;
  }
  .cc-prompt-chevrons {
    color: #d97757;
  }
  .cc-prompt-dim {
    color: var(--color-ink-faint);
  }
  @keyframes cc-prompt-blink {
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cc-prompt-cursor {
      animation: none;
    }
  }
</style>
