---
/**
 * Inline reference to a GitHub pull request or issue, rendered as a small
 * GitHub-style token: a state-colored Octicon (merged = purple, open = green,
 * closed = red) followed by the monospace number. Themed via the global CSS
 * custom properties, so it tracks light/dark automatically.
 *
 *   <PR id={984} />                          → juspay/kolu#984  (merged PR)
 *   <PR id={951} kind="issue" />             → juspay/kolu#951  (open issue)
 *   <PR id={1071} state="open" />            → an open PR
 *   <PR id={5817} repo="xtermjs/xterm.js" /> → xtermjs/xterm.js#5817
 *
 * Props: id (required); repo (default "juspay/kolu"); kind ("pull" | "issue",
 * default "pull"); state ("merged" | "open" | "closed"). Default state is
 * "merged" for pulls and "open" for issues — the common case when citing
 * shipped work; pass `state` to override.
 */
interface Props {
  id: number | string;
  repo?: string;
  kind?: "pull" | "issue";
  state?: "merged" | "open" | "closed";
}

const DEFAULT_REPO = "juspay/kolu";
const { id, repo = DEFAULT_REPO, kind = "pull" } = Astro.props;
const state = Astro.props.state ?? (kind === "pull" ? "merged" : "open");

// GitHub URL segment: PRs live under /pull/<n>, issues under /issues/<n>.
const PATH = { pull: "pull", issue: "issues" } as const;
const href = `https://github.com/${repo}/${PATH[kind]}/${id}`;
const label = `${repo === DEFAULT_REPO ? "" : repo}#${id}`;

// Pick the Octicon that matches GitHub's own state iconography.
const iconKey =
  kind === "issue"
    ? state === "closed"
      ? "issueClosed"
      : "issueOpen"
    : state === "merged"
      ? "merged"
      : state === "closed"
        ? "prClosed"
        : "prOpen";

// Octicons, 16px.
const ICON: Record<string, string> = {
  prOpen:
    "M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z",
  merged:
    "M5.45 5.154A4.25 4.25 0 0 0 9.25 7.5h1.378a2.251 2.251 0 1 1 0 1.5H9.25A5.734 5.734 0 0 1 5 7.123v3.505a2.25 2.25 0 1 1-1.5 0V5.372a2.25 2.25 0 1 1 1.95-.218ZM4.25 13.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm8.5-4.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z",
  prClosed:
    "M3.25 1A2.25 2.25 0 0 1 4 5.372v5.256a2.25 2.25 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 3.25 1Zm9.5 14a2.25 2.25 0 1 1 0-4.5 2.25 2.25 0 0 1 0 4.5ZM2.5 3.25a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0ZM3.25 12a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm9.5 0a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm1.28-8.53a.75.75 0 0 0-1.06 0l-1.97 1.97-.97-.97a.749.749 0 0 0-1.275.326.749.749 0 0 0 .215.734l1.5 1.5a.75.75 0 0 0 1.06 0l2.5-2.5a.75.75 0 0 0 0-1.06Z",
  issueOpen:
    "M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3ZM8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0Z",
  issueClosed:
    "M11.28 6.78a.75.75 0 0 0-1.06-1.06L7.25 8.69 5.78 7.22a.75.75 0 0 0-1.06 1.06l2 2a.75.75 0 0 0 1.06 0l3.5-3.5ZM16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0Zm-1.5 0a6.5 6.5 0 1 0-13 0 6.5 6.5 0 0 0 13 0Z",
};
---

<a
  class="pr-ref"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  data-state={state}
>
  <svg
    class="pr-ref-icon"
    viewBox="0 0 16 16"
    width="1em"
    height="1em"
    aria-hidden="true"
    fill="currentColor"
  >
    <path d={ICON[iconKey]}></path>
  </svg><span class="pr-ref-num">{label}</span>
</a>

<style>
  .pr-ref {
    --pr-state: var(--color-amber);
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-family: var(--font-mono);
    font-size: 0.82em;
    font-weight: 500;
    line-height: 1;
    padding: 0.14em 0.5em 0.14em 0.4em;
    border-radius: 2em;
    text-decoration: none;
    white-space: nowrap;
    vertical-align: baseline;
    color: var(--pr-state);
    background: color-mix(in srgb, var(--pr-state) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--pr-state) 28%, transparent);
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .pr-ref[data-state="merged"] {
    --pr-state: var(--color-amber);
  }
  .pr-ref[data-state="open"] {
    --pr-state: var(--color-brand-green);
  }
  .pr-ref[data-state="closed"] {
    --pr-state: var(--color-brand-red);
  }
  .pr-ref:hover {
    background: color-mix(in srgb, var(--pr-state) 22%, transparent);
    border-color: color-mix(in srgb, var(--pr-state) 55%, transparent);
  }
  .pr-ref-icon {
    flex: none;
  }
</style>
