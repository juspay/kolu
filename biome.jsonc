// Phase 12 of #710: flip on the `a11y` rule group. 88 findings split
// across mechanical (useButtonType, noSvgWithoutTitle) and judgment
// (noStaticElementInteractions on canvas widgets). The 4 spatial-mouse
// sites in `canvas/CanvasMinimap.tsx` and `canvas/CanvasTile.tsx` keep
// the rules off via overrides â€” see the bottom of this file for why.
{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!pnpm-lock.yaml",
      "!apm.lock.yaml",
      "!AGENTS.md",
      "!CLAUDE.md",
      "!.claude/agents",
      "!.claude/commands",
      "!.claude/rules",
      "!.claude/skills",
      "!.claude/hooks",
      "!.claude/settings.json",
      "!.agents",
      "!.codex",
      "!.opencode",
      "!opencode.json",
      // Claude Code dynamic-workflow scripts use top-level return/await and
      // runtime-injected globals (agent/phase/log/...) â€” they aren't valid
      // standalone ES modules, so biome can't parse them. Authored, not linted.
      "!**/*.workflow.js",
      "!**/dist",
      "!**/node_modules",
      "!**/.direnv",
      "!**/.logs",
      "!patches",
      // Astro files: frontmatter imports/consts are resolved inside the template
      // body, which Biome doesn't parse â€” lint + format would false-positive
      // and corrupt files. Astro has its own formatter (future: astro fmt).
      "!**/*.astro",
      // One-off heap-snapshot analyzers; not part of the product surface.
      "!docs/perf-investigations/scripts",
      // Top-level HTML files are design / plan artifacts, not shipping code.
      "!*.html"
    ]
  },
  // Biome is now the sole formatter â€” Prettier has been retired (#710).
  // Defaults mirror the old Prettier defaults (2-space indent, 80-column,
  // double quotes, semicolons, trailing commas) so the one-shot churn
  // from the flip is whitespace-minimal.
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "linter": {
    "enabled": true,
    // `project` domain unlocks Biome's type-aware rules (Scanner-backed).
    // Per-rule opt-in: only the rules explicitly turned on below fire;
    // Scanner runs lazily for files touched by those rules.
    "domains": {
      "project": "all"
    },
    "rules": {
      "recommended": true,
      "nursery": {
        // Unawaited promises that silently swallow errors â€” the
        // flagship motivation for adopting Biome (#710).
        "noFloatingPromises": "error",
        // Type-aware exhaustiveness on discriminated unions â€” adding a
        // new variant forces every `switch` site to handle it.
        "useExhaustiveSwitchCases": "error",
        // Promises passed where `void` is expected â€” e.g. Solid
        // `<button onClick={asyncFn}>` silently swallows errors.
        "noMisusedPromises": "error"
      },
      "performance": {
        // Solid domain: prefer `<For each={â€¦}>` over `items.map(â€¦)` so
        // list reactivity is keyed properly instead of re-rendering on
        // every signal change.
        "useSolidForComponent": "error"
      },
      // `ci::biome` runs with `--error-on-warnings`, so there is no silent
      // advisory tier: every `recommended` rule either fails the build or is
      // explicitly turned off here (or scoped off in `overrides`) with the
      // reason it stays advisory. The baseline stays `recommended: true` so
      // rules promoted in future Biome releases surface on the next upgrade â€”
      // and, because the gate is strict, must be triaged (fix or off) in the
      // PR that bumps Biome rather than accruing as invisible debt (#1362).
      "suspicious": {
        // Terminal code legitimately parses ANSI escape sequences â€”
        // the rule is a permanent false positive against xterm diagnostics.
        "noControlCharactersInRegex": "off",
        // Promoted from the default `warn` after #1005 broke the 9 server
        // cycles via the `surfaceCtx.ts` holder pattern. As `error`, any
        // PR that re-introduces a cycle fails `just check` immediately â€”
        // the TDZ-on-import-reorder class becomes structurally impossible.
        "noImportCycles": "error"
      },
      "complexity": {
        // Tailwind `!important` overrides are intentional in kolu's
        // rare CSS escape-hatches.
        "noImportantStyles": "off"
      },
      "style": {
        // The `!` non-null assertion is a sanctioned escape hatch here:
        // `Map.get(k)` after a `.has(k)` guard, array indices the surrounding
        // code proves present, and similar spots where the value is known
        // non-null. Replacing them with runtime guards would only add branches
        // that can never execute. The load-bearing safety rules
        // (noFloatingPromises, noMisusedPromises, noImportCycles) are promoted
        // to `error` separately â€” `!` carries no such hazard, so it stays off
        // rather than advisory-but-unenforced.
        "noNonNullAssertion": "off"
      },
      "correctness": {
        // Project-domain rule: 293 sites of bare relative imports that
        // would need `.ts`/`.tsx` extensions. Kolu uses TS's
        // `moduleResolution: bundler` which resolves without extensions;
        // flipping this on is an independent migration.
        "useImportExtensions": "off",
        // Project-domain rule: 39 findings. Triggers on path-aliased
        // imports Biome's resolver doesn't understand the same way tsc
        // does; dedicated follow-up needed to align them.
        "noUnresolvedImports": "off"
      }
    }
  },
  "css": {
    // Kolu uses Tailwind v4 (`@theme`, `@plugin`, `@apply`) in both the
    // client and the website â€” without this flag the CSS parser rejects
    // those directives even on lint-only runs.
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      // `defineSurface`'s generic machinery is a library over *heterogeneous*
      // descriptor maps: `Record<string, CellSpec<any, any>>` and the mapped
      // types that walk it. `unknown` can't stand in â€” a concrete
      // `CellSpec<Note>` is not assignable to `CellSpec<unknown>` in these
      // invariant container/constraint positions, so the spec object a caller
      // writes would stop type-checking. The `any`s are confined to this one
      // file's type plumbing (every value flows through Zod schemas at the
      // edges), so the rule is scoped off here rather than repo-wide.
      "includes": ["packages/surface/src/define.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      // Test code uses idioms production code doesn't: async generators
      // that throw before yielding (error-path tests) and assign-in-expr
      // patterns (indexOf loops, Cucumber world-scratch fields).
      "includes": ["**/*.test.ts", "**/*.test.tsx", "packages/tests/**"],
      "linter": {
        "rules": {
          "correctness": {
            "useYield": "off"
          },
          "suspicious": {
            "noAssignInExpressions": "off"
          }
        }
      }
    },
    {
      // Spatial-mouse canvas widgets: the minimap (drag-to-pan, click
      // empty space to recenter, drag tile rectangles to rearrange) and
      // the canvas tile wrapper (mousedown to focus, drag-to-rearrange)
      // are inherently pointer-driven. Synthetic `role="button"` +
      // `tabIndex={0}` + a fake `onKeyDown` would *claim* keyboard
      // accessibility without delivering it â€” worse than no claim.
      //
      // Real keyboard navigation across terminals is provided by the
      // command palette (âŒ˜K, fuzzy search), the pill tree (sidebar,
      // arrow-key tree nav), and the âŒ˜1..9 / âŒ˜J shortcuts. Those are
      // the canonical a11y entry points for tile selection; the canvas
      // is the visual layer they drive.
      "includes": [
        "packages/client/src/canvas/CanvasMinimap.tsx",
        "packages/client/src/canvas/CanvasTile.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "off",
            "useKeyWithClickEvents": "off",
            "noNoninteractiveElementInteractions": "off"
          }
        }
      }
    }
  ]
}
