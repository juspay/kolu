# @kolu/surface mini-ci — standalone example.
#
# `just run` is parametrized — every argument passes straight through to the
# TUI, so one recipe covers local and remote:
#
#   just run                          local: spawn the runner as a child
#   just run --remote user@host       remote: ship source via `git archive |
#                                     ssh tar -x`, then `nix run` the runner on
#                                     the host (needs passwordless ssh + Nix
#                                     there — it builds from the shipped source)
#   just run --pipeline ci.json       local, the diamond pipeline
#   just run --remote user@host --headless   scriptable (or --json)

repo_root := justfile_directory() / "../../../.."
nix_shell := if env('IN_NIX_SHELL', '') != '' { '' } else { 'nix develop ' + repo_root + ' --accept-flake-config -c' }

# List available recipes
default:
    @just --list

# Install pnpm deps (delegates to the workspace at the repo root)
install:
    cd {{ repo_root }} && {{ nix_shell }} pnpm install

# Run the pipeline. Args pass straight to the TUI (see header for examples).
run *args: install
    cd {{ justfile_directory() }} && {{ nix_shell }} pnpm start -- {{ args }}

# Typecheck this example only
typecheck:
    cd {{ justfile_directory() }} && {{ nix_shell }} pnpm typecheck

# Run this example's unit tests
test:
    cd {{ justfile_directory() }} && {{ nix_shell }} pnpm test:unit
