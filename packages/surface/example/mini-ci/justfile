# @kolu/surface mini-ci — standalone example.
#
# `just run` runs the built-in pipeline locally: the TUI spawns the runner
# as a child and attaches over stdio. `just run-remote <host>` ships a clean
# source snapshot with `git archive | ssh host tar -x` and `nix run`s the
# runner on the host over ssh stdio. Needs passwordless ssh + Nix on the host
# (Nix builds the runner from the shipped source — no node/pnpm assumed).

repo_root := justfile_directory() / "../../../.."
nix_shell := if env('IN_NIX_SHELL', '') != '' { '' } else { 'nix develop ' + repo_root + ' --accept-flake-config -c' }

# List available recipes
default:
    @just --list

# Install pnpm deps (delegates to the workspace at the repo root)
install:
    cd {{ repo_root }} && {{ nix_shell }} pnpm install

# Run the built-in pipeline locally (interactive dashboard).
run *args: install
    cd {{ justfile_directory() }} && {{ nix_shell }} pnpm start {{ args }}

# Run the diamond example pipeline (build → {test, lint} → report).
run-diamond: install
    cd {{ justfile_directory() }} && {{ nix_shell }} pnpm start -- --pipeline ci.json

# Ship source over ssh and run the pipeline on a remote host.
run-remote host *args: install
    cd {{ justfile_directory() }} && {{ nix_shell }} pnpm start -- --remote {{ host }} {{ args }}

# Typecheck this example only
typecheck:
    cd {{ justfile_directory() }} && {{ nix_shell }} pnpm typecheck

# Run this example's unit tests
test:
    cd {{ justfile_directory() }} && {{ nix_shell }} pnpm test:unit
